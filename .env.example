# Copy this file to `.env` or `.env.local` for local development.
# The runtime also accepts `APIFY_TOKEN` as an alias for `SHOPEASE_APIFY_TOKEN`.

DJANGO_SECRET_KEY=<django-secret-key>
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Active backend database: Supabase Postgres via Supavisor pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres?sslmode=require
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<neo4j-password>

RECOMMENDATIONS_BASE_URL=http://localhost:8001

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

GOOGLE_WEB_CLIENT_ID=

SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=

SHOPEASE_AI_ENABLED=false
SHOPEASE_AI_MODE=off
SHOPEASE_AI_PIPELINE_ENABLED=false

SHOPEASE_APIFY_ENABLED=true
SHOPEASE_APIFY_TOKEN=<apify-api-token>
SHOPEASE_APIFY_BASE_URL=https://api.apify.com/v2
SHOPEASE_APIFY_ACTOR_ID=apify~google-search-scraper
SHOPEASE_APIFY_TIMEOUT_MS=30000
SHOPEASE_APIFY_RESULTS_PER_PAGE=10
SHOPEASE_APIFY_MAX_PAGES_PER_QUERY=1
SHOPEASE_APIFY_COUNTRY=US
SHOPEASE_APIFY_LANGUAGE=en
SHOPEASE_APIFY_DOMAIN=com
SHOPEASE_APIFY_ALLOWLIST=amazon.com,walmart.com,target.com
SHOPEASE_APIFY_CACHE_TTL_SECONDS=21600
SHOPEASE_APIFY_MAX_VARIANTS=3
SHOPEASE_APIFY_MAX_URLS_PER_PROVIDER=6
SHOPEASE_APIFY_TOTAL_BUDGET_MS=25000
SHOPEASE_APIFY_PROVIDER_EXTRACTION_TIMEOUT_MS=30000

# Deprecated: legacy self-hosted discovery settings. The live search path now uses Apify.
# SHOPEASE_SEARXNG_ENABLED=true
# SHOPEASE_SEARXNG_BASE_URL=http://127.0.0.1:8088
