# Copy this file to `.env` or `.env.local` for local development.
# The runtime also accepts `APIFY_TOKEN` as an alias for `AIXSTORE_APIFY_TOKEN`.

DJANGO_SECRET_KEY=<django-secret-key>
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Active backend database: Supabase Postgres via Supavisor pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<pooler-host>:6543/postgres?sslmode=require
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<neo4j-password>

RECOMMENDATIONS_BASE_URL=http://localhost:8001

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

GOOGLE_WEB_CLIENT_ID=

SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=

AIXSTORE_AI_ENABLED=false
AIXSTORE_AI_MODE=off
AIXSTORE_AI_PIPELINE_ENABLED=false

AIXSTORE_APIFY_ENABLED=true
AIXSTORE_APIFY_TOKEN=<apify-api-token>
AIXSTORE_APIFY_BASE_URL=https://api.apify.com/v2
AIXSTORE_APIFY_ACTOR_ID=apify~google-search-scraper
AIXSTORE_APIFY_TIMEOUT_MS=30000
AIXSTORE_APIFY_RESULTS_PER_PAGE=10
AIXSTORE_APIFY_MAX_PAGES_PER_QUERY=1
AIXSTORE_APIFY_COUNTRY=US
AIXSTORE_APIFY_LANGUAGE=en
AIXSTORE_APIFY_DOMAIN=com
AIXSTORE_APIFY_ALLOWLIST=amazon.com,walmart.com,target.com
AIXSTORE_APIFY_CACHE_TTL_SECONDS=21600
AIXSTORE_APIFY_MAX_VARIANTS=3
AIXSTORE_APIFY_MAX_URLS_PER_PROVIDER=6
AIXSTORE_APIFY_TOTAL_BUDGET_MS=25000
AIXSTORE_APIFY_PROVIDER_EXTRACTION_TIMEOUT_MS=30000

# Optional: local ports (defaults match scripts/start-mobile-live.mjs).
# AIXSTORE_RUNTIME_PORT=7860
# AIXSTORE_PYTHON_PORT=8790
# AIXSTORE_METRO_PORT=8081
# Wait for emulator/device before Expo (android mode only), milliseconds.
# AIXSTORE_ADB_WAIT_MS=240000
# AIXSTORE_ADB_BOOT_WAIT_MS=120000

# Deprecated: legacy self-hosted discovery settings. The live search path now uses Apify.
# AIXSTORE_SEARXNG_ENABLED=true
# AIXSTORE_SEARXNG_BASE_URL=http://127.0.0.1:8088
