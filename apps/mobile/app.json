{
  "expo": {
    "name": "AIXStore",
    "slug": "aixstore",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/aix-store-icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/aix-store-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAFF"
    },
    "android": {
      "package": "com.aixstore.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/aix-store-mark.png",
        "backgroundColor": "#F7FAFF"
      }
    }
  }
}
